# Generated:  {{ timestamp }}
# Board:      {{ board_type }}
# Clock:      {{ clock_mhz }} MHz
# Source:     project_config.yaml + ip_registry.yaml
#
# Complete flat Quartus pin assignment file.
# Source directly from pre_flow.tcl -- no dynamic HAL chain needed.
# Do NOT edit manually; re-run gen_config.py to regenerate.

# -------------------------------------------------------------------------
# Device
# -------------------------------------------------------------------------
set_global_assignment -name FAMILY "Cyclone IV E"
set_global_assignment -name DEVICE  EP4CE55F23C8

# -------------------------------------------------------------------------
# System clock & reset
# -------------------------------------------------------------------------
set_location_assignment PIN_T2  -to SYS_CLK
set_instance_assignment  -name IO_STANDARD           "3.3-V LVTTL" -to SYS_CLK
set_location_assignment PIN_W13 -to RESET_N
set_instance_assignment  -name IO_STANDARD           "3.3-V LVTTL" -to RESET_N
set_instance_assignment  -name WEAK_PULL_UP_RESISTOR ON             -to RESET_N

# -------------------------------------------------------------------------
# On-board peripherals
# -------------------------------------------------------------------------
{% if use_uart %}
# UART  (TX=PIN_J1  RX=PIN_J2)
set_location_assignment PIN_J1 -to UART_TX
set_instance_assignment  -name IO_STANDARD           "3.3-V LVTTL" -to UART_TX
set_location_assignment PIN_J2 -to UART_RX
set_instance_assignment  -name IO_STANDARD           "3.3-V LVTTL" -to UART_RX
set_instance_assignment  -name WEAK_PULL_UP_RESISTOR ON             -to UART_RX
{% endif %}
{% for blk in onboard_blocks %}

# {{ blk.label }}
set_instance_assignment  -name IO_STANDARD "{{ blk.io_std }}" -to {{ blk.signal }}[*]
{% if blk.pull_up %}
set_instance_assignment  -name WEAK_PULL_UP_RESISTOR ON -to {{ blk.signal }}[*]
{% endif %}
{% for pin_entry in blk.pins %}
set_location_assignment {{ pin_entry.pin }} -to {{ blk.signal }}[{{ pin_entry.idx }}]
{% endfor %}
{% endfor %}
{% if pmod_blocks %}

# -------------------------------------------------------------------------
# PMOD connectors
# -------------------------------------------------------------------------
{% for blk in pmod_blocks %}

# PMOD {{ blk.port }} -> {{ blk.module }}  (IO: {{ blk.io_std }})
set_instance_assignment  -name IO_STANDARD "{{ blk.io_std }}" -to {{ blk.signal }}[*]
{% for pin_entry in blk.pins %}
set_location_assignment {{ pin_entry.pin }} -to {{ blk.signal }}[{{ pin_entry.idx }}]
{% endfor %}
{% endfor %}
{% endif %}

# -------------------------------------------------------------------------
# soc_top external ports  (peripheral -> physical pin summary)
# -------------------------------------------------------------------------
{% for ep in ext_port_summary %}
# {{ "%-22s"|format(ep.inst + "." + ep.top_port) }}  {{ ep.dir }}{% if ep.width > 1 %}  [{{ ep.width-1 }}:0]{% endif %}

{% endfor %}
