# =============================================================================
# AUTO-GENERATED BY gen_config.py - DO NOT EDIT MANUALLY
# Generated:  {{ timestamp }}
# =============================================================================
# Clock domains: {{ all_clock_names | join(', ') }}
# =============================================================================

# =============================================================================
# 1. Input (board) clocks
# =============================================================================
{% for clk in clocks %}
# {{ clk.name }}  {{ clk.freq_mhz }} MHz  (period {{ clk.period_ns }} ns)
create_clock \
  -period {{ clk.period_ns }} \
  -name   {{ clk.name }} \
  [get_ports { {{ clk.port }} }]
{% endfor %}

# =============================================================================
# 2. PLL generated clocks
# =============================================================================
{% if generated_clocks %}
{% for gc in generated_clocks %}
# {{ gc.name }}{% if gc.freq_mhz %}  {{ gc.freq_mhz }} MHz  (period {{ gc.period_ns }} ns){% endif %}

create_generated_clock \
  -name      {{ gc.name }} \
  -source    [get_ports { {{ gc.source_port }} }] \
  -multiply_by {{ gc.multiply_by }} \
  -divide_by   {{ gc.divide_by }} \
{% if gc.offset_ns %}
  -offset    {{ gc.offset_ns }} \
{% endif %}
  [get_pins { {{ gc.pin_path }} }]
{% endfor %}
{% else %}
# (no PLL clocks defined)
{% endif %}

# =============================================================================
# 3. Clock domain groups  (asynchronous / exclusive)
# =============================================================================
{% if clock_groups %}
{% for grp in clock_groups %}
set_clock_groups \
  -{{ grp.type }} \
{% for g in grp.groups %}
  -group [get_clocks { {{ g | join(' ') }} }]{{ "" if loop.last else " \\" }}
{% endfor %}

{% endfor %}
{% else %}
# (no clock groups defined -- all clocks treated as related)
{% endif %}

# =============================================================================
# 4. Clock uncertainty
# =============================================================================
{% if derive_uncertainty %}
derive_clock_uncertainty
{% endif %}

# =============================================================================
# 5. False paths
# =============================================================================
{% if false_paths %}
{% for fp in false_paths %}
{% if fp.comment %}
# {{ fp.comment }}
{% endif %}
{% if fp.type == 'from_port' %}
set_false_path -from [get_ports { {{ fp.value }} }]
{% elif fp.type == 'cdc_reset' %}
set_false_path \
  -from [get_clocks { {{ fp.from_clock }} }] \
  -to   [get_clocks { {{ fp.to_clock }} }]
{% elif fp.type == 'cell' %}
set_false_path \
{% if fp.from_cell %}  -from [get_cells { {{ fp.from_cell }} }] \{% endif %}

{% if fp.to_cell %}  -to   [get_cells { {{ fp.to_cell }} }]{% endif %}

{% endif %}
{% endfor %}
{% else %}
# (no false paths defined)
{% endif %}

# =============================================================================
# 6. IO delays
# =============================================================================
{% if io_delays %}
{% for d in io_delays %}
{% if d.comment %}
# {{ d.comment }}
{% endif %}
set_{{ d.direction }}_delay \
  -clock [get_clocks { {{ d.clock }} }] \
  -max   {{ d.max_ns }} \
  [get_ports { {{ d.port }} }]
{% endfor %}
{% else %}
# (no IO delay constraints defined)
{% endif %}

# =============================================================================
# 7. Multicycle paths
# =============================================================================
{% if multicycle_paths %}
{% for mp in multicycle_paths %}
{% if mp.comment %}
# {{ mp.comment }}
{% endif %}
{% if mp.setup %}
set_multicycle_path \
  -setup \
  -num_paths {{ mp.cycles }} \
{% if mp.from_cell %}  -from [get_cells { {{ mp.from_cell }} }] \{% endif %}

{% if mp.to_cell %}  -to   [get_cells { {{ mp.to_cell }} }] \{% endif %}

{% if mp.from_clock %}  -from [get_clocks { {{ mp.from_clock }} }] \{% endif %}

{% if mp.to_clock %}  -to   [get_clocks { {{ mp.to_clock }} }]{% endif %}

{% endif %}
{% if mp.hold %}
set_multicycle_path \
  -hold \
  -num_paths {{ mp.cycles - 1 }} \
{% if mp.from_cell %}  -from [get_cells { {{ mp.from_cell }} }] \{% endif %}

{% if mp.to_cell %}  -to   [get_cells { {{ mp.to_cell }} }] \{% endif %}

{% if mp.from_clock %}  -from [get_clocks { {{ mp.from_clock }} }] \{% endif %}

{% if mp.to_clock %}  -to   [get_clocks { {{ mp.to_clock }} }]{% endif %}

{% endif %}
{% endfor %}
{% else %}
# (no multicycle path constraints defined)
{% endif %}

# =============================================================================
# 8. Reset synchroniser documentation
# =============================================================================
{% if reset_syncs %}
# The following reset synchronisers must be instantiated in RTL (rst_sync.sv):
#
{% for rs in reset_syncs %}
# {{ "%-30s" | format(rs.inst_name) }}  domain={{ rs.domain }}  stages={{ rs.sync_stages }}  type={{ rs.type }}{% if rs.sync_from %}  sync_from={{ rs.sync_from }}{% endif %}

{% endfor %}
#
# Module interface (rst_sync.sv):
#   rst_sync #(.STAGES(N)) u_name (
#     .clk_i    ( <domain_clock> ),
#     .rst_ni   ( RESET_N        ),   // async assert
#     .rst_no   ( <domain_rst_n> )    // sync release
#   );
{% endif %}

# =============================================================================
# End of timing constraints
# =============================================================================
