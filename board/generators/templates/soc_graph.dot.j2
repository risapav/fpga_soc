// AUTO-GENERATED BY gen_config.py - DO NOT EDIT MANUALLY
// SoC: {{ board_type }}  CPU: {{ cpu_type }}  RAM: {{ ram_size }} B  @{{ clock_mhz }} MHz
digraph soc {
  graph [rankdir=LR fontname="Helvetica" bgcolor="#fafafa"
         label="" splines=ortho nodesep=0.6 ranksep=1.2];
  node  [fontname="Helvetica" fontsize=10];
  edge  [fontname="Helvetica" fontsize=9];

  // CPU
  cpu [label="{{ cpu_type }}\n(CPU)" shape=box3d
       style=filled fillcolor="#ffe0b2" color="#e65100" fontcolor="#e65100"];

  // RAM
  ram [label="soc_ram\n0x{{ '%X' % ram_base }}..0x{{ '%X' % ram_end }}"
       shape=cylinder style=filled fillcolor="#e8eaf6" color="#3949ab"];

  cpu -> ram [color="#3949ab" penwidth=2];

{% for fabric in fabrics %}
  // Bus fabric: {{ fabric.bus_type }}
  subgraph cluster_{{ loop.index0 }} {
    label="{{ fabric.bus_type }}";
    style=filled; fillcolor="{{ fabric.colour }}";
    color="#999999"; fontsize=9;
{% for p in fabric.slaves %}
    {{ p.inst }} [label="{{ p.inst }}\n0x{{ '%08X' % p.base }}{{ p.irq_label }}{{ p.reg_label }}"
                  shape=box style=filled fillcolor="{{ fabric.colour }}" color="#555555"];
{% endfor %}
  }

{% endfor %}
{% for fabric in fabrics %}
{% for p in fabric.slaves %}
  cpu -> {{ p.inst }} [color="#555555" penwidth=1.5 label="{{ fabric.bus_type }}"];
{% endfor %}
{% endfor %}

{% for bridge in bridges %}
  {{ bridge.src }} -> {{ bridge.dst }}
    [label="{{ bridge.module }}" style=bold color="#e65100"
     constraint=false fontcolor="#e65100"];
{% endfor %}

{% for p in irq_nodes %}
  {{ p.inst }} -> cpu [label="IRQ {{ p.irq_ids }}" style=dashed
                        color="#c62828" fontcolor="#c62828" constraint=false];
{% endfor %}

{% if show_clk_rst %}
  SYS_CLK [label="SYS_CLK" shape=diamond style=filled fillcolor="#fff9c4"];
  RESET_N [label="RESET_N" shape=diamond style=filled fillcolor="#fce4ec"];
{% for e in clk_rst_edges %}
  {{ e.target }} -> {{ e.source }} [style=dotted color="{{ e.colour }}" constraint=false];
{% endfor %}
{% endif %}
}
